# ==================================
# PostgreSQL Configuration
# ==================================
POSTGRES_DB=rh_database
POSTGRES_USER=rh_user
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD_HERE

# ==================================
# Spring Boot Configuration
# ==================================
SPRING_PROFILES_ACTIVE=prod
PORT=8080

# Database connection (Docker network)
# The backend container connects to postgres:5432 (Docker service name)
DATABASE_URL=jdbc:postgresql://postgres:5432/rh_database
DB_USERNAME=rh_user
DB_PASSWORD=YOUR_STRONG_PASSWORD_HERE

# ==================================
# JWT Security (REQUIRED - Generate with: openssl rand -base64 64)
# ==================================
JWT_SECRET=YOUR_64_CHAR_BASE64_JWT_SECRET_HERE
JWT_EXPIRATION_HOURS=12

# ==================================
# Frontend URLs (for CORS)
# ==================================
FRONTEND_URL=http://2.24.15.95,https://2.24.15.95

# ==================================
# Email Configuration (Optional)
# ==================================
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password

# ==================================
# Google Drive Integration (Optional)
# ==================================
GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY_PATH=service-account.json
GOOGLE_DRIVE_CLIENT_VIEWER_KEY_PATH=client-viewer-service-account.json
GOOGLE_DRIVE_PARENT_FOLDER_ID=your-folder-id
GOOGLE_DRIVE_REDIRECT_URI=https://2.24.15.95/api/media-plans/google-drive/callback
